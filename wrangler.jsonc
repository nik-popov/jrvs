{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "jrvs",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "vars": {
    // Hermes 2 Pro is purpose-built for reliable native function calling and
    // emits clean speakable text alongside tool calls. Qwen is the fallback,
    // used only when the primary model throws (never on empty text, so a
    // successful tool call is never re-run / double-fired).
    "WORKERS_AI_MODEL": "@hf/nousresearch/hermes-2-pro-mistral-7b",
    "WORKERS_AI_FALLBACK_MODEL": "@cf/qwen/qwen2.5-coder-32b-instruct",
    // Where JRVS files its own feature requests (request_feature tool).
    "GITHUB_REPO": "nik-popov/jrvs"
  },
  "version_metadata": {
    // D1 blueprint: lets the agent detect new deployments (deployment_tx).
    "binding": "CF_VERSION_METADATA"
  },
  "ai": {
    "binding": "AI",
    // Voice models (STT/TTS) run remotely even during local dev.
    // Requires `wrangler login` (or CLOUDFLARE_API_TOKEN) — AI bindings
    // have no local simulator.
    "remote": true
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "JarvisAgent",
        "name": "JarvisAgent"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["JarvisAgent"],
      "tag": "v1"
    }
  ],
  "assets": {
    "not_found_handling": "single-page-application",
    // Agent WebSocket/API traffic must hit the Worker (and its auth gate) first;
    // /auth/* carries the Google OAuth callback
    "run_worker_first": ["/agents/*", "/auth/*"]
  },
  "observability": {
    "enabled": true
  }
}
